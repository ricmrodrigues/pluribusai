# Copy to .env and customize:  cp .env.example .env
#
# Shared bearer token for your team (optional — leave empty to disable auth).
PLURIBUSAI_TOKEN=change-me-to-a-long-random-string

# Per-user API keys (recommended for shared servers). Generate with:
#   python3 scripts/gen-api-keys.py alice bob > deploy/examples/api-keys.json
# PLURIBUSAI_API_KEYS_FILE=/run/secrets/api-keys.json

# Postgres compose (docker-compose.postgres.yml):
# POSTGRES_PASSWORD=change-me-postgres

# Server observability:
# PLURIBUSAI_LOG_FORMAT=json
# PLURIBUSAI_HTTP_PORT=8787

# Client installer (install/install.sh):
#   PLURIBUSAI_ENDPOINT=http://localhost:8787
#   PLURIBUSAI_TOKEN=<same token or per-user pk_...>
#   PLURIBUSAI_USER=yourname