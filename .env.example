# Copy to .env and customize:  cp .env.example .env
#
# Shared bearer token for your team (optional — leave empty to disable auth).
PLURIBUSAI_TOKEN=change-me-to-a-long-random-string

# Client installer (install/install.sh):
#   PLURIBUSAI_ENDPOINT=http://localhost:8787
#   PLURIBUSAI_TOKEN=<same token>
#   PLURIBUSAI_USER=yourname